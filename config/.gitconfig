[alias]
    st = status
    cmm = commit -m
    aa = add .
    co = checkout
    cob = checkout -b
    lg = log --graph --pretty=format:'%Cred%h %C(reset)%s %C(green)(%cd)' --abbrev-commit -5
    lgn = "lg --name-only"
    bra = branch
	cma = "!git add -A && git commit -m"
	cp = cherry-pick
	ap = add -p
[user]
    email = chris@elserinteractive.com
    name = Chris Vann
[gpg]
    program = /usr/bin/gpg
[diff]
    tool = vimdiff
[merge]
    tool = vimdiff
[push]
	followTags = true
[log]
	date = human

